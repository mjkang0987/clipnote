# ClipNote 환경변수 예시 — 실제 값은 .env.local 에 넣으세요(커밋 금지).

# Supabase (서버 전용 — 클립 저장). 없으면 메모리 저장소로 자동 폴백.
# Supabase 대시보드 → Project Settings → API 에서 확인.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (브라우저 인증용 — 공개 키라 노출 OK). 로그인에 필요.
# URL 은 위 SUPABASE_URL 과 동일, KEY 는 anon/publishable 키.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 사이트 기본 URL (OG 이미지 절대경로 등에 사용). 로컬은 http://localhost:4000
NEXT_PUBLIC_SITE_URL=https://clipnote.co.kr

# 네이버 로그인 (커스텀 OAuth — Supabase 미지원 provider).
# developers.naver.com 앱의 Client ID/Secret. Callback URL 에
#   <도메인>/api/auth/naver/callback (로컬: http://localhost:4000/api/auth/naver/callback)
# 을 등록해야 한다. 네이버는 이메일을 받지 않고 고유 id 로만 식별한다.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
